<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="PharmacyApp.Features.Period_Tracker.Views.PeriodTrackerPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:viewModels="using:PharmacyApp.Features.Period_Tracker.ViewModels"
    mc:Ignorable="d">

    <ScrollViewer VerticalScrollMode="Enabled"
                  HorizontalScrollMode="Enabled"
                  Width="Auto"
                  Height="Auto">

        <Grid RowSpacing="20" Padding="25" CanBeScrollAnchor="True">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Important dates -->
            <StackPanel Orientation="Horizontal"
                        Spacing="15"
                        VerticalAlignment="Center"
                        HorizontalAlignment="Center"
                        Visibility="{x:Bind ViewModel.CalendarsVisibility, Mode=OneWay}">
                <Grid Padding="30" ColumnSpacing="30" CornerRadius="20" Opacity="1">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.ColumnSpan="3"
                               Padding="0 0 0 20"
                               Text="{x:Bind ViewModel.Calendars.CurrentMonth, Mode=OneWay}"
                               VerticalAlignment="Center"
                               HorizontalAlignment="Center"
                               FontSize="30"
                               Foreground="DarkSlateGray"
                               FontWeight="Bold"/>

                    <StackPanel Grid.Column="0"
                                Grid.Row="1"
                                CornerRadius="10"
                                Orientation="Vertical"
                                VerticalAlignment="Center"
                                HorizontalAlignment="Left"
                                Spacing="5"
                                Padding="10 10 120 10"
                                Background="SlateGray">
                        <StackPanel Spacing="10" Orientation="Horizontal" VerticalAlignment="Top" Margin="0 0 0 30">
                            <SymbolIcon Symbol="Calendar"/>
                            <TextBlock Text="Today" Opacity="0.9" FontWeight="Bold" VerticalAlignment="Top"/>
                        </StackPanel>
                        <TextBlock Foreground="Black"
                                   Text="{x:Bind ViewModel.Calendars.LiterallyTodayString, Mode=OneWay}"
                                   FontSize="20"
                                   FontWeight="Bold"
                                   VerticalAlignment="Bottom"/>
                        <TextBlock Foreground="Pink"
                                   Text="{x:Bind ViewModel.Calendars.CurrentPhaseString, Mode=OneWay}"
                                   FontSize="12"
                                   VerticalAlignment="Bottom"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1"
                                Grid.Row="1"
                                CornerRadius="10"
                                Orientation="Vertical"
                                VerticalAlignment="Center"
                                HorizontalAlignment="Left"
                                Spacing="5"
                                Padding="10 10 120 10"
                                Background="SlateGray">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Top" Margin="0 0 0 30" Spacing="10">
                            <SymbolIcon Symbol="Favorite"/>
                            <TextBlock Text="Next Period" Opacity="0.9" FontWeight="Bold" VerticalAlignment="Top"/>
                        </StackPanel>
                        <TextBlock Foreground="Black"
                                   Text="{x:Bind ViewModel.Calendars.NextPeriodDateString, Mode=OneWay}"
                                   FontSize="20"
                                   FontWeight="Bold"
                                   VerticalAlignment="Bottom"/>
                        <TextBlock Foreground="Pink"
                                   Text="{x:Bind ViewModel.Calendars.NextPeriodDistanceString, Mode=OneWay}"
                                   FontSize="12"
                                   VerticalAlignment="Bottom"/>
                    </StackPanel>

                    <StackPanel Grid.Column="2"
                                Grid.Row="1"
                                CornerRadius="10"
                                Orientation="Vertical"
                                VerticalAlignment="Center"
                                HorizontalAlignment="Left"
                                Spacing="5"
                                Padding="10 10 120 10"
                                Background="SlateGray">
                        <StackPanel Spacing="10" Orientation="Horizontal" VerticalAlignment="Top" Margin="0 0 0 30">
                            <SymbolIcon Symbol="Share"/>
                            <TextBlock Text="Ovulation" Opacity="0.9" FontWeight="Bold" VerticalAlignment="Top"/>
                        </StackPanel>
                        <TextBlock Foreground="Black"
                                   Text="{x:Bind ViewModel.Calendars.CurrentOvulationDateString, Mode=OneWay}"
                                   FontSize="20"
                                   FontWeight="Bold"
                                   VerticalAlignment="Bottom"/>
                        <TextBlock Foreground="LightYellow"
                                   Text="{x:Bind ViewModel.Calendars.PastOvulationString, Mode=OneWay}"
                                   FontSize="12"
                                   VerticalAlignment="Bottom"/>
                    </StackPanel>
                </Grid>
            </StackPanel>

            <!-- Calendar intervals -->
            <StackPanel Grid.Row="1"
                        Orientation="Horizontal"
                        Spacing="10"
                        VerticalAlignment="Center"
                        HorizontalAlignment="Center"
                        Visibility="{x:Bind ViewModel.CalendarsVisibility, Mode=OneWay}">
                <Button Command="{x:Bind ViewModel.PreviousCycleCommand}"
                        Style="{StaticResource SubtleButtonStyle}"
                        Content="&lt;"
                        Width="40"
                        Height="40"
                        FontSize="25"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Padding="0 0 0 10"/>

                <StackPanel Orientation="Vertical"
                            Spacing="20"
                            VerticalAlignment="Center"
                            HorizontalAlignment="Center"
                            MinWidth="500">
                    <StackPanel Orientation="Horizontal" Spacing="3" HorizontalAlignment="Center">
                        <Rectangle Width="10" Height="10" Fill="Pink" Stroke="Black"/>
                        <TextBlock FontSize="17"
                                   Foreground="Pink"
                                   FontWeight="Bold"
                                   Text="{x:Bind ViewModel.Calendars.PeriodInterval, Mode=OneWay}"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Spacing="3" HorizontalAlignment="Center">
                        <Rectangle Width="10" Height="10" Fill="LightGreen" Stroke="Black"/>
                        <TextBlock FontSize="16"
                                   Foreground="LightGreen"
                                   Text="{x:Bind ViewModel.Calendars.LowFertilityInterval, Mode=OneWay}"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Spacing="3" HorizontalAlignment="Center">
                        <Rectangle Width="10" Height="10" Fill="Aqua" Stroke="Black"/>
                        <TextBlock FontSize="16"
                                   Foreground="Aqua"
                                   Text="{x:Bind ViewModel.Calendars.OvulationInterval, Mode=OneWay}"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Spacing="3" HorizontalAlignment="Center">
                        <Rectangle Width="10" Height="10" Fill="OrangeRed" Stroke="Black"/>
                        <TextBlock FontSize="16"
                                   Foreground="OrangeRed"
                                   Text="{x:Bind ViewModel.Calendars.PmsInterval, Mode=OneWay}"/>
                    </StackPanel>
                </StackPanel>

                <Button Command="{x:Bind ViewModel.NextCycleCommand}"
                        Style="{StaticResource SubtleButtonStyle}"
                        Content="&gt;"
                        Width="40"
                        Height="40"
                        FontSize="25"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Padding="0 0 0 10"/>
            </StackPanel>

            <!-- Inputs -->
            <StackPanel Grid.Row="2"
                        Orientation="Horizontal"
                        Spacing="20"
                        VerticalAlignment="Center"
                        HorizontalAlignment="Center">

                <DatePicker Date="{x:Bind ViewModel.StartPeriodDate, Mode=TwoWay}"
                            Header="Start Date of Last Period"
                            DayFormat="{}{day.integer} ({dayofweek.abbreviated})"/>

                <NumberBox Header="How much did your last period last:"
                           Value="{x:Bind ViewModel.PeriodLastsInput, Mode=TwoWay}"
                           SpinButtonPlacementMode="Inline"
                           SmallChange="1"
                           Height="80"
                           Minimum="1"
                           Maximum="9"
                           Width="160"/>

                <NumberBox Minimum="20"
                           Maximum="45"
                           Header="How much does your average cycle last:"
                           Value="{x:Bind ViewModel.CycleDaysInput, Mode=TwoWay}"
                           SpinButtonPlacementMode="Inline"
                           SmallChange="1"
                           Height="80"
                           Width="160"/>

                <StackPanel Orientation="Vertical"
                            Spacing="20"
                            VerticalAlignment="Center"
                            HorizontalAlignment="Center">
                    <RadioButtons Header="When do PMS symptoms appear:"
                                  SelectedIndex="{x:Bind ViewModel.PremenstrualSyndromeOptionInput, Mode=TwoWay}">
                        <RadioButton Content="Not applicable"/>
                        <RadioButton Content="1-3 days before period"/>
                        <RadioButton Content="4-7 days before period"/>
                        <RadioButton Content="7-14 days before period"/>
                    </RadioButtons>
                </StackPanel>
            </StackPanel>

            <!-- Calculate -->
            <Button Grid.Row="3"
                    Command="{x:Bind ViewModel.CalculateCommand}"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">
                CALCULATE
            </Button>

            <!-- Notes -->
            <StackPanel Grid.Row="4"
                        Orientation="Horizontal"
                        VerticalAlignment="Center"
                        HorizontalAlignment="Center">
                <GridView SelectionMode="None"
                          HorizontalAlignment="Center"
                          VerticalAlignment="Center"
                          ItemsSource="{x:Bind ViewModel.Notes, Mode=OneWay}">

                    <GridView.ItemContainerStyle>
                        <Style TargetType="GridViewItem" BasedOn="{StaticResource DefaultGridViewItemStyle}">
                            <Setter Property="Margin" Value="10, 10, 10, 10"/>
                            <Setter Property="MaxWidth" Value="250"/>
                        </Style>
                    </GridView.ItemContainerStyle>

                    <GridView.ItemsPanel>
                        <ItemsPanelTemplate>
                            <ItemsWrapGrid MaximumRowsOrColumns="4" Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </GridView.ItemsPanel>

                    <GridView.ItemTemplate>
                        <DataTemplate x:DataType="viewModels:NoteViewModel">
                            <StackPanel Orientation="Horizontal"
                                        Spacing="0"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        Width="220"
                                        Height="100">
                                <CheckBox IsChecked="{x:Bind NoteIsDone, Mode=TwoWay}"
                                          VerticalAlignment="Top"
                                          HorizontalAlignment="Right"
                                          MaxWidth="20"
                                          Margin="0 -5 -98 0"/>

                                <TextBox Text="{x:Bind NoteBody, Mode=TwoWay}"
                                         FontStyle="{x:Bind NoteBodyFontStyle, Mode=OneWay}"
                                         TextWrapping="Wrap"
                                         AcceptsReturn="True"
                                         Width="150"
                                         Height="100"
                                         MaxLength="100"/>

                                <Button Command="{x:Bind DeleteNoteCommand}"
                                        Content="x"
                                        VerticalAlignment="Top"
                                        Style="{StaticResource SubtleButtonStyle}"
                                        Margin="-8 0 0 0"
                                        Width="30"/>
                            </StackPanel>
                        </DataTemplate>
                    </GridView.ItemTemplate>
                </GridView>

                <Button Command="{x:Bind ViewModel.AddNoteCommand}"
                        Visibility="{x:Bind ViewModel.AddNoteVisibility, Mode=OneWay}"
                        Margin="0 10 0 0"
                        VerticalAlignment="Top"
                        HorizontalAlignment="Left"
                        MaxWidth="50"
                        MaxHeight="50">
                    +
                </Button>
            </StackPanel>

            <!-- Recommended items -->
            <FlipView Grid.Row="5"
                      SelectedIndex="0"
                      Visibility="{x:Bind ViewModel.ShopVisibility, Mode=OneWay}"
                      HorizontalAlignment="Center"
                      ItemsSource="{x:Bind ViewModel.ItemsLists, Mode=OneWay}"
                      Height="180"
                      Width="800">

                <FlipView.ItemTemplate>
                    <DataTemplate x:DataType="viewModels:ItemListViewModel">
                        <ItemsControl ItemsSource="{x:Bind Items}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Horizontal"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>

                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="viewModels:ItemViewModel">
                                    <Grid Width="180" Margin="10 0 10 0">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="40"/>
                                            <RowDefinition Height="40"/>
                                            <RowDefinition Height="40"/>
                                            <RowDefinition Height="40"/>
                                        </Grid.RowDefinitions>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="100"/>
                                        </Grid.ColumnDefinitions>

                                        <Image Width="70"
                                               Source="{x:Bind ImagePath}"
                                               Grid.Row="0"
                                               Grid.RowSpan="3"
                                               Grid.Column="0"/>

                                        <TextBlock Text="{x:Bind Name}"
                                                   Grid.Row="0"
                                                   Grid.Column="1"
                                                   HorizontalAlignment="Left"
                                                   VerticalAlignment="Top"
                                                   TextWrapping="WrapWholeWords"/>

                                        <TextBlock TextDecorations="Strikethrough"
                                                   Foreground="{x:Bind PriceColor}"
                                                   Text="{x:Bind PriceDiscountedString}"
                                                   Grid.Row="1"
                                                   Grid.Column="1"
                                                   Margin="0 0 0 -10"
                                                   HorizontalAlignment="Right"
                                                   VerticalAlignment="Bottom"/>

                                        <TextBlock Foreground="{x:Bind FinalPriceColor}"
                                                   Text="{x:Bind PriceString}"
                                                   Grid.Row="2"
                                                   Grid.Column="1"
                                                   HorizontalAlignment="Right"
                                                   VerticalAlignment="Bottom"
                                                   Padding="0 0 0 10"/>

                                        <Button Width="150"
                                                Grid.Column="0"
                                                Grid.Row="3"
                                                Grid.ColumnSpan="2"
                                                Content="Add to basket"
                                                Command="{x:Bind AddToBasketCommand}"/>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </DataTemplate>
                </FlipView.ItemTemplate>
            </FlipView>
        </Grid>
    </ScrollViewer>
</Page>